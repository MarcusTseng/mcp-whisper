# Required: bearer token clients send as `Authorization: Bearer <token>`.
# Generate with: `openssl rand -hex 32`
# The HTTP transport refuses to start without this.
MCP_AUTH_TOKEN=replace-me-with-openssl-rand-hex-32

# Optional: Discord webhook URL for update.sh notifications.
# If unset, update.sh runs silently (no Discord posts).
DISCORD_WEBHOOK_URL=
